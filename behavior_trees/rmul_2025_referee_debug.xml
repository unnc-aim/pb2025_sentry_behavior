<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <!-- ========================================= -->
  <!-- rmul_2025_referee_debug                   -->
  <!-- With referee system. Small area debug.    -->
  <!-- Path: (0,0)->(1,0)->(1,1)->(0,1)         -->
  <!-- Gimbal yaw follows velocity direction.    -->
  <!-- ========================================= -->

  <!-- ============================== -->
  <!-- Subtree: check_game_start      -->
  <!-- Checks if game is running or   -->
  <!-- manual start is triggered.     -->
  <!-- If neither, stops the robot.   -->
  <!-- ============================== -->
  <BehaviorTree ID="check_game_start">
    <Fallback>
      <IsGameStatus name="IsGameStart"
                    max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <IsManualStart key_port="{@manual_start}"
                     start_value="1"/>
      <ForceFailure>
        <Sequence>
          <PublishSpinSpeed spin_speed="0.0"
                            duration="0"
                            topic_name="cmd_spin"/>
          <PublishTwist v_y="0.0"
                        v_yaw="0.0"
                        v_x="0.0"
                        duration="0"
                        topic_name="cmd_vel"/>
          <PublishAutoAim value="0"
                          duration="0"
                          topic_name="auto_aim_switch"/>
        </Sequence>
      </ForceFailure>
    </Fallback>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: patrol_path           -->
  <!-- Navigate continuously through: -->
  <!--   (1,0) -> (1,1) -> (0,1)     -->
  <!-- yaw: 0 -> pi/2 -> pi          -->
  <!-- ============================== -->
  <BehaviorTree ID="patrol_path">
    <SendNav2ThroughPoses goals="1;0;0|1;1;1.5708|0;1;3.14159"
                          action_name="navigate_through_poses"/>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: scan_until_hp_low     -->
  <!-- At destination (0,1):          -->
  <!--   - Enable auto-aim            -->
  <!--   - Start gimbal scan          -->
  <!--   - Keep running until HP low  -->
  <!-- ============================== -->
  <BehaviorTree ID="scan_until_hp_low">
    <Sequence>
      <PublishAutoAim value="1"
                      duration="0"
                      topic_name="auto_aim_switch"/>
      <ForceSuccess>
        <ReactiveSequence>
          <IsStatusOK ammo_min="0"
                      heat_max="9999"
                      hp_min="200"
                      hp_port="{@referee_robotPerformance}"
                      heat_port="{@referee_robotHeat}"
                      ammo_port="{@referee_allowedShoot}"/>
          <KeepRunningUntilFailure>
            <Sequence>
              <PublishGimbalVelocity gimbal_vel_yaw="1.0"
                                     gimbal_vel_pitch="0.0"
                                     yaw_min="-3.14159"
                                     yaw_max="0.0"
                                     pitch_min="-0.5"
                                     pitch_max="0.5"
                                     duration="0"
                                     topic_name="gimbal_scan_cmd"/>
              <PublishAutoAim value="1"
                              duration="0"
                              topic_name="auto_aim_switch"/>
              <Sleep msec="2000"/>
            </Sequence>
          </KeepRunningUntilFailure>
        </ReactiveSequence>
      </ForceSuccess>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: retreat_and_recover   -->
  <!-- Disable scan, retreat to base, -->
  <!-- wait for HP recovery.          -->
  <!-- Path: (0,1)->(1,1)->(1,0)->   -->
  <!--        (0,0)                   -->
  <!-- yaw: -pi/2 -> pi -> pi        -->
  <!-- ============================== -->
  <BehaviorTree ID="retreat_and_recover">
    <Sequence>
      <PublishAutoAim value="0"
                      duration="0"
                      topic_name="auto_aim_switch"/>
      <PublishGimbalVelocity gimbal_vel_yaw="0.0"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-1.57"
                             pitch_max="1.57"
                             duration="0"
                             topic_name="gimbal_scan_cmd"/>
      <SendNav2ThroughPoses goals="1;1;-1.5708|1;0;3.14159|0;0;3.14159"
                            action_name="navigate_through_poses"/>
      <PublishTwist v_x="0.0"
                    v_y="0.0"
                    v_yaw="0.0"
                    duration="0"
                    topic_name="cmd_vel"/>
      <RetryUntilSuccessful num_attempts="-1">
        <Sequence>
          <Sleep msec="1000"/>
          <IsStatusOK ammo_min="0"
                      heat_max="9999"
                      hp_min="300"
                      hp_port="{@referee_robotPerformance}"
                      heat_port="{@referee_robotHeat}"
                      ammo_port="{@referee_allowedShoot}"/>
        </Sequence>
      </RetryUntilSuccessful>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: navigate_with_retreat -->
  <!-- ============================== -->
  <BehaviorTree ID="navigate_with_retreat">
    <Sequence>
      <SubTree ID="patrol_path"/>
      <SubTree ID="scan_until_hp_low"/>
      <SubTree ID="retreat_and_recover"/>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: gimbal_init           -->
  <!-- ============================== -->
  <BehaviorTree ID="gimbal_init">
    <Sequence>
      <PublishGimbalVelocity gimbal_vel_yaw="0.5"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-0.5"
                             pitch_max="0.5"
                             duration="13000"
                             topic_name="gimbal_scan_cmd"/>
      <Sleep msec="5000"/>
      <PublishGimbalVelocity gimbal_vel_yaw="0.5"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-0.5"
                             pitch_max="0.5"
                             duration="13000"
                             topic_name="gimbal_scan_cmd"/>
      <PrintRefereeStatus/>
    </Sequence>
  </BehaviorTree>

  <!-- ========================================= -->
  <!-- Main tree: rmul_2025_referee_debug        -->
  <!-- ========================================= -->
  <BehaviorTree ID="rmul_2025_referee_debug">
    <Sequence>
      <SubTree ID="gimbal_init"/>
      <KeepRunningUntilFailure>
        <ForceSuccess>
          <ReactiveSequence>
            <SubTree ID="check_game_start"/>
            <Sequence>
              <PublishSpinSpeed spin_speed="7.0"
                                duration="0"
                                topic_name="cmd_spin"/>
              <SubTree ID="navigate_with_retreat"/>
            </Sequence>
          </ReactiveSequence>
        </ForceSuccess>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

</root>
