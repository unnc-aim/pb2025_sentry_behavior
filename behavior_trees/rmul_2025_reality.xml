<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <!-- ============================== -->
  <!-- Subtree: check_game_start      -->
  <!-- Checks if game is running or   -->
  <!-- manual start is triggered.     -->
  <!-- If neither, stops the robot.   -->
  <!-- ============================== -->
  <BehaviorTree ID="check_game_start">
    <Fallback>
      <IsGameStatus name="IsGameStart"
                    max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <IsManualStart key_port="{@manual_start}"
                     start_value="1"/>
      <ForceFailure>
        <Sequence>
          <PublishSpinSpeed spin_speed="0.0"
                            duration="0"
                            topic_name="cmd_spin"/>
          <PublishTwist v_y="0.0"
                        v_yaw="0.0"
                        v_x="0.0"
                        duration="0"
                        topic_name="cmd_vel"/>
          <PublishAutoAim value="0"
                          duration="0"
                          topic_name="auto_aim_switch"/>
        </Sequence>
      </ForceFailure>
    </Fallback>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: patrol_path           -->
  <!-- Navigate: start -> (6,0) ->   -->
  <!--   (6,5.25) -> (3,5.25)        -->
  <!-- Large tolerance on waypoints   -->
  <!-- for continuous motion.         -->
  <!-- ============================== -->
  <BehaviorTree ID="patrol_path">
    <SendNav2ThroughPoses goals="6;0;0|6;5.25;0|3;5.25;0"
                          action_name="navigate_through_poses"/>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: scan_until_hp_low     -->
  <!-- At destination (3,5.25):       -->
  <!--   - Enable auto-aim            -->
  <!--   - Start gimbal 180° scan     -->
  <!--   - Keep running until HP low  -->
  <!-- ============================== -->
  <BehaviorTree ID="scan_until_hp_low">
    <Sequence>
      <!-- Enable auto-aim -->
      <PublishAutoAim value="1"
                      duration="0"
                      topic_name="auto_aim_switch"/>
      <!-- Keep scanning until HP drops below threshold -->
      <ForceSuccess>
        <ReactiveSequence>
          <IsStatusOK ammo_min="0"
                      heat_max="9999"
                      hp_min="200"
                      hp_port="{@referee_robotPerformance}"
                      heat_port="{@referee_robotHeat}"
                      ammo_port="{@referee_allowedShoot}"/>
          <KeepRunningUntilFailure>
            <Sequence>
              <!-- Re-publish gimbal scan command periodically -->
              <PublishGimbalVelocity gimbal_vel_yaw="1.0"
                                     gimbal_vel_pitch="0.0"
                                     yaw_min="-3.14159"
                                     yaw_max="0.0"
                                     pitch_min="-0.5"
                                     pitch_max="0.5"
                                     duration="0"
                                     topic_name="gimbal_scan_cmd"/>
              <!-- Re-publish auto-aim command periodically -->
              <PublishAutoAim value="1"
                              duration="0"
                              topic_name="auto_aim_switch"/>
              <Sleep msec="2000"/>
            </Sequence>
          </KeepRunningUntilFailure>
        </ReactiveSequence>
      </ForceSuccess>
      <!-- HP is low now, reaching here means we should retreat -->
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: retreat_and_recover   -->
  <!-- Disable scan, retreat to base, -->
  <!-- wait for HP recovery.          -->
  <!-- Path: (6,5.25)->(6,0)->(0,0)  -->
  <!-- ============================== -->
  <BehaviorTree ID="retreat_and_recover">
    <Sequence>
      <!-- Disable auto-aim -->
      <PublishAutoAim value="0"
                      duration="0"
                      topic_name="auto_aim_switch"/>
      <!-- Stop gimbal scan -->
      <PublishGimbalVelocity gimbal_vel_yaw="0.0"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-1.57"
                             pitch_max="1.57"
                             duration="0"
                             topic_name="gimbal_scan_cmd"/>
      <!-- Retreat: continuous path back to base -->
      <SendNav2ThroughPoses goals="6;5.25;0|6;0;0|0;0;0"
                            action_name="navigate_through_poses"/>
      <!-- Stop movement at base -->
      <PublishTwist v_x="0.0"
                    v_y="0.0"
                    v_yaw="0.0"
                    duration="0"
                    topic_name="cmd_vel"/>
      <!-- Wait for HP recovery (hp >= 300) -->
      <RetryUntilSuccessful num_attempts="-1">
        <Sequence>
          <Sleep msec="1000"/>
          <IsStatusOK ammo_min="0"
                      heat_max="9999"
                      hp_min="300"
                      hp_port="{@referee_robotPerformance}"
                      heat_port="{@referee_robotHeat}"
                      ammo_port="{@referee_allowedShoot}"/>
        </Sequence>
      </RetryUntilSuccessful>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: navigate_with_retreat -->
  <!-- Full mission cycle:            -->
  <!--   1) Patrol to (3,5.25)        -->
  <!--   2) Scan + auto-aim           -->
  <!--   3) Retreat when HP low       -->
  <!--   4) Recover, then repeat      -->
  <!-- ============================== -->
  <BehaviorTree ID="navigate_with_retreat">
    <Sequence>
      <SubTree ID="patrol_path"/>
      <SubTree ID="scan_until_hp_low"/>
      <SubTree ID="retreat_and_recover"/>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Subtree: gimbal_init           -->
  <!-- Spin gimbal full circle twice  -->
  <!-- with 5s pause in between.      -->
  <!-- ============================== -->
  <BehaviorTree ID="gimbal_init">
    <Sequence>
      <!-- First full circle at moderate speed -->
      <PublishGimbalVelocity gimbal_vel_yaw="0.5"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-0.5"
                             pitch_max="0.5"
                             duration="13000"
                             topic_name="gimbal_scan_cmd"/>
      <!-- Pause 5 seconds -->
      <Sleep msec="2000"/>
      <!-- Second full circle -->
      <PublishGimbalVelocity gimbal_vel_yaw="0.5"
                             gimbal_vel_pitch="0.0"
                             yaw_min="-3.14159"
                             yaw_max="3.14159"
                             pitch_min="-0.5"
                             pitch_max="0.5"
                             duration="13000"
                             topic_name="gimbal_scan_cmd"/>
      <!-- Log gimbal init success -->
      <PrintRefereeStatus/>
    </Sequence>
  </BehaviorTree>

  <!-- ============================== -->
  <!-- Main tree: rmul_2025_reality   -->
  <!-- ============================== -->
  <BehaviorTree ID="rmul_2025_reality">
    <Sequence>
      <!-- Gimbal initialization (runs once) -->
      <SubTree ID="gimbal_init"/>
      <!-- Main loop -->
      <KeepRunningUntilFailure>
        <ForceSuccess>
          <ReactiveSequence>
            <SubTree ID="check_game_start"/>
            <Sequence>
              <PublishSpinSpeed spin_speed="7.0"
                                duration="0"
                                topic_name="cmd_spin"/>
              <SubTree ID="navigate_with_retreat"/>
            </Sequence>
          </ReactiveSequence>
        </ForceSuccess>
      </KeepRunningUntilFailure>
    </Sequence>
  </BehaviorTree>

</root>
